{
  "nodes": [
    {"id": "file:migration_oracle/pipeline/extractors/wildfly.py","type": "file","name": "wildfly.py","filePath": "migration_oracle/pipeline/extractors/wildfly.py","summary": "Implements the WildFlyExtractor, an async HTTP extractor that discovers WildFly versions from Maven Central, fetches GitHub release notes, and enriches parsed changes with Jira issue metadata via concurrent async requests.","tags": ["service", "api-handler", "extractor", "async"],"complexity": "complex"},
    {"id": "class:migration_oracle/pipeline/extractors/wildfly.py:WildFlyExtractor","type": "class","name": "WildFlyExtractor","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [41, 181],"summary": "Concrete extractor for WildFly that extends BaseExtractor, providing version discovery from Maven metadata, GitHub release-note parsing, and Jira-based change enrichment with configurable concurrency.","tags": ["service", "extractor", "async", "api-handler"],"complexity": "complex"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly.py:discover_versions","type": "function","name": "discover_versions","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [49, 64],"summary": "Fetches and normalizes all WildFly release versions from Maven Central metadata XML, optionally filtering out pre-release and non-GA versions.","tags": ["async", "extractor", "version-discovery"],"complexity": "moderate"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly.py:enrich_with_jira","type": "function","name": "enrich_with_jira","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [66, 122],"summary": "Synchronously enriches a list of DocumentedChange objects by replacing Jira-key placeholders with full issue summaries, descriptions, and priority metadata sourced from a pre-built Jira cache.","tags": ["utility", "enrichment", "data-model"],"complexity": "complex"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly.py:_load_jira_cache","type": "function","name": "_load_jira_cache","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [124, 143],"summary": "Concurrently fetches Jira issue data for all keys found in a release body and change statements, using a semaphore to limit concurrent requests.","tags": ["async", "caching", "concurrency"],"complexity": "moderate"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly.py:extract","type": "function","name": "extract","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [145, 162],"summary": "Main extraction entry point: fetches the release body for a WildFly version hop, parses changes, performs Jira enrichment, and returns an ExtractionResult.","tags": ["async", "entry-point", "extractor"],"complexity": "moderate"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly.py:_fetch_release_body","type": "function","name": "_fetch_release_body","filePath": "migration_oracle/pipeline/extractors/wildfly.py","lineRange": [164, 181],"summary": "Resolves the release body text for a given WildFly version by trying GitHub releases, then the official migration guide HTML, with a news-page fallback.","tags": ["async", "http", "fallback"],"complexity": "moderate"},
    {"id": "file:migration_oracle/pipeline/extractors/wildfly_jira.py","type": "file","name": "wildfly_jira.py","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","summary": "Provides standalone Jira enrichment helpers for WildFly, including regex-based Jira key extraction, REST and HTML scraping fetch logic, and result parsing into typed cache entries.","tags": ["utility", "service", "api-handler", "enrichment"],"complexity": "complex"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:normalize_jira_url","type": "function","name": "normalize_jira_url","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [48, 52],"summary": "Rewrites legacy issues.redhat.com Jira browse URLs to the current redhat.atlassian.net domain.","tags": ["utility", "url-normalization"],"complexity": "simple"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:build_release_index","type": "function","name": "build_release_index","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [55, 80],"summary": "Scans a release body for all Jira key references (plain and HTML-export formats) and builds an index mapping each key to a stub WildFlyJiraEntry.","tags": ["utility", "parsing", "data-model"],"complexity": "moderate"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:collect_jira_keys","type": "function","name": "collect_jira_keys","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [83, 87],"summary": "Collects the union of all Jira keys found in a release body and a list of change statement strings.","tags": ["utility", "parsing"],"complexity": "simple"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:parse_jira_fields","type": "function","name": "parse_jira_fields","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [90, 101],"summary": "Converts a raw Jira REST API fields dict into a typed WildFlyJiraEntry with normalized summary, description, issue type, and priority.","tags": ["utility", "serialization", "data-model"],"complexity": "simple"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:fetch_jira_entry","type": "function","name": "fetch_jira_entry","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [104, 156],"summary": "Async function that fetches a Jira issue entry by first trying the REST API JSON endpoint, then falling back to HTML scraping of the browse URL using BeautifulSoup.","tags": ["async", "api-handler", "http", "fallback"],"complexity": "complex"},
    {"id": "function:migration_oracle/pipeline/extractors/wildfly_jira.py:enrich_with_jira","type": "function","name": "enrich_with_jira","filePath": "migration_oracle/pipeline/extractors/wildfly_jira.py","lineRange": [159, 168],"summary": "Async compatibility shim that drives the full Jira enrichment pipeline via an extractor instance; used by legacy callers and tests.","tags": ["async", "enrichment", "utility"],"complexity": "simple"},
    {"id": "file:tests/extractors/test_wildfly.py","type": "file","name": "test_wildfly.py","filePath": "tests/extractors/test_wildfly.py","summary": "Integration test for WildFlyExtractor.extract that mocks Maven metadata, GitHub releases, and the Jira REST API with respx to verify end-to-end change extraction.","tags": ["test", "integration-test", "async"],"complexity": "simple"},
    {"id": "file:tests/extractors/test_wildfly_jira.py","type": "file","name": "test_wildfly_jira.py","filePath": "tests/extractors/test_wildfly_jira.py","summary": "Unit tests for the WildFly Jira enrichment helpers, covering Jira key collection from release bodies and the full enrich_with_jira pipeline with mocked HTTP responses.","tags": ["test", "unit-test", "async"],"complexity": "simple"}
  ],
